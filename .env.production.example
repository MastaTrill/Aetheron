# Production Environment Configuration for Aetheron Platform
# Copy this to .env.production and fill in your actual values
# NEVER commit this file to version control!

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
DATABASE_URL=postgresql://aetheron:your_secure_password@postgres:5432/aetheron
POSTGRES_PASSWORD=your_secure_postgres_password
REDIS_PASSWORD=your_secure_redis_password

# ==========================================
# BLOCKCHAIN & DEPLOYMENT
# ==========================================
ALCHEMY_API_KEY=your_alchemy_api_key
INFURA_PROJECT_ID=your_infura_project_id
ETHERSCAN_API_KEY=your_etherscan_api_key
POLYGONSCAN_API_KEY=your_polygonscan_api_key
BASESCAN_API_KEY=your_basescan_api_key

# CRITICAL: Use a dedicated deployment wallet, NOT your main wallet!
DEPLOYER_PRIVATE_KEY=your_64_char_private_key_no_0x

# ==========================================
# AUTHENTICATION & SECURITY
# ==========================================
JWT_SECRET=your_very_long_random_jwt_secret_at_least_32_chars
SESSION_SECRET=your_session_secret_for_express_sessions

# ==========================================
# PAYMENT & FIAT GATEWAYS
# ==========================================
STRIPE_API_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
MOONPAY_API_KEY=your_moonpay_api_key
RAMP_API_KEY=your_ramp_api_key

# ==========================================
# ACCOUNT ABSTRACTION
# ==========================================
BUNDLER_URL=https://bundler.example.com
PAYMASTER_URL=https://paymaster.example.com

# ==========================================
# NOTIFICATIONS
# ==========================================
SENDGRID_API_KEY=SG.your_sendgrid_api_key
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ==========================================
# EXTERNAL APIs
# ==========================================
COINGECKO_API_KEY=your_coingecko_api_key
DEFI_PULSE_API_KEY=your_defi_pulse_api_key

# ==========================================
# MONITORING & LOGGING
# ==========================================
LOG_LEVEL=info
SENTRY_DSN=https://your_sentry_dsn@sentry.io/project_id
PROMETHEUS_PORT=9090

# ==========================================
# APPLICATION CONFIG
# ==========================================
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# FILE STORAGE
# ==========================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=aetheron-production

# Alternative: Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=your_gcp_project
GOOGLE_CLOUD_KEY_FILE=path/to/service-account.json

# ==========================================
# BACKUP CONFIGURATION
# ==========================================
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=aetheron-backups

# ==========================================
# SSL & SECURITY
# ==========================================
SSL_CERT_PATH=/etc/ssl/certs/aetheron.crt
SSL_KEY_PATH=/etc/ssl/private/aetheron.key
FORCE_HTTPS=true

# ==========================================
# FEATURE FLAGS
# ==========================================
ENABLE_ANALYTICS=true
ENABLE_NOTIFICATIONS=true
ENABLE_SOCIAL_AUTH=true
ENABLE_FIAT_GATEWAY=true
ENABLE_PROMETHEUS=true
ENABLE_RATE_LIMITING=true