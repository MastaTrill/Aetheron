# Environment Variables for Production

# Server Configuration
NODE_ENV=production
PORT=3001
HOST=0.0.0.0

# Database (PostgreSQL)
DATABASE_URL=postgresql://username:password@localhost:5432/aetheron

# Redis Cache
REDIS_URL=redis://default:password@redis-host:6379

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-secure-password

# Blockchain RPC Endpoints
ETHEREUM_RPC=https://eth-mainnet.g.alchemy.com/v2/YOUR-API-KEY
BASE_RPC=https://base-mainnet.g.alchemy.com/v2/YOUR-API-KEY
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR-API-KEY
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Fiat On-Ramp Providers
MOONPAY_API_KEY=your-moonpay-api-key
MOONPAY_SECRET_KEY=your-moonpay-secret-key
MOONPAY_WEBHOOK_SECRET=your-moonpay-webhook-secret

STRIPE_API_KEY=sk_live_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_live_your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

TRANSAK_API_KEY=your-transak-api-key
TRANSAK_SECRET_KEY=your-transak-secret-key

# Account Abstraction (ERC-4337)
BUNDLER_URL=https://bundler.biconomy.io/api/v2/YOUR-CHAIN-ID
PAYMASTER_URL=https://paymaster.biconomy.io/api/v1/YOUR-CHAIN-ID
BUNDLER_API_KEY=your-bundler-api-key
PAYMASTER_API_KEY=your-paymaster-api-key

# Email Service (SendGrid)
SENDGRID_API_KEY=SG.your-sendgrid-api-key
FROM_EMAIL=aetheron.solana@gmail.com

# SMS Service (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# IPFS/Decentralized Storage
IPFS_API_URL=https://ipfs.infura.io:5001
IPFS_PROJECT_ID=your-ipfs-project-id
IPFS_PROJECT_SECRET=your-ipfs-secret

# Analytics & Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key

# Security
CORS_ORIGIN=https://yourdomain.com
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=900000

# L2 Integration
ZKSYNC_RPC=https://mainnet.era.zksync.io
ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC=https://mainnet.optimism.io
BASE_RPC=https://mainnet.base.org

# Smart Contract Addresses
MULTISIG_WALLET=0x0000000000000000000000000000000000000000
DAO_GOVERNANCE=0x0000000000000000000000000000000000000000
TOKEN_CONTRACT=0x0000000000000000000000000000000000000000

# Feature Flags
ENABLE_FIAT_ONRAMP=true
ENABLE_LIMIT_ORDERS=true
ENABLE_RWA_TOKENIZATION=true
ENABLE_L2_INTEGRATION=true
ENABLE_ACCOUNT_ABSTRACTION=true

# Compliance
KYC_PROVIDER=sumsub
KYC_API_KEY=your-kyc-provider-api-key
KYC_SECRET_KEY=your-kyc-provider-secret

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
