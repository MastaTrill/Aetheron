{
  "name": "aetheron-dashboard",
  "version": "1.0.0",
  "description": "Aetheron Admin Dashboard with Backend Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration",
    "test:e2e": "playwright test",
    "db:migrate": "node database/migrate.js",
    "db:seed": "node database/seed.js",
    "health": "node health-check.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "cli": "node cli/aetheron.js",
    "backup": "node backup-recovery.js backup",
    "restore": "node backup-recovery.js restore",
    "security:scan": "node security-automation.js scan",
    "security:audit": "node security-automation.js audit",
    "docker:build": "docker build -t aetheron .",
    "docker:run": "docker run -p 3001:3001 aetheron",
    "docker:compose": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "deploy:all": "cd deployment && bash deploy.sh",
    "deploy:us-east": "cd deployment && bash deploy.sh us-east",
    "deploy:eu": "cd deployment && bash deploy.sh eu",
    "build:frontend": "cd frontend && npx webpack --mode=production",
    "build:frontend:dev": "cd frontend && npx webpack --mode=development",
    "serve:frontend": "cd frontend && npx webpack serve --mode=development",
    "setup": "npm install --legacy-peer-deps && node set-admin-password.js"
  },
  "dependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.6",
    "@mui/material": "^7.3.6",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/native": "^7.1.10",
    "@react-navigation/native-stack": "^7.3.14",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "ethers": "^6.16.0",
    "express": "^4.21.2",
    "express-graphql": "^0.12.0",
    "graphql": "^15.10.1",
    "graphql-subscriptions": "^2.0.0",
    "inquirer": "^8.2.7",
    "jsonwebtoken": "^9.0.2",
    "ora": "^5.4.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "qrcode-terminal": "^0.12.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native-camera": "^4.2.1",
    "react-native-permissions": "^5.4.1",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-safe-area-context": "^5.4.1",
    "react-native-screens": "^4.11.1",
    "recharts": "^3.6.0",
    "sequelize": "^6.35.2",
    "socket.io-client": "^4.8.3",
    "speakeasy": "^2.0.0",
    "sqlite3": "^5.1.7",
    "stripe": "^14.25.0",
    "table": "^6.9.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/eslint-parser": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.11",
    "@types/testing-library__react": "^10.0.1",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.6.5",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "style-loader": "^4.0.0",
    "supertest": "^6.3.3",
    "webpack": "^5.104.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "keywords": [
    "aetheron",
    "blockchain",
    "admin",
    "dashboard",
    "crypto",
    "solana",
    "ethereum",
    "base",
    "polygon",
    "multichain"
  ],
  "author": "Aetheron Team",
  "license": "MIT"
}
